[user]
    name = Carlo Teubner
    email = carlo@cteubner.net

[init]
    defaultBranch = main

[diff]
    algorithm = histogram
    colorMoved = dimmed-zebra
    mnemonicPrefix = true
    ; tool = nvimdiff
    tool = nvim_difftool

[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"

[commit]
    verbose = true

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

[merge]
    conflictStyle = zdiff3
    tool = nvimdiff

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[rerere]
    enabled = true

[fetch]
    prune = true

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[credential]
    helper = cache

[sendemail]
    confirm = auto
    smtpServer = smtp.fastmail.com
    smtpServerPort = 465
    smtpEncryption = ssl
    smtpUser = carlo@cteubner.net

[interactive]
    singleKey = true

[column]
    ui = auto

[advice]
    detachedHead = false

[alias]
    pushf = push --force-with-lease

[url "https://github.com/"]
    insteadOf = g:

[url "git@github.com:"]
    insteadOf = G:

[url "git@github.com:c4rlo/"]
    insteadOf = c:

; [url "git@gitlab.com:"]  -- gives me "git@gitlab.com: Permission denied (publickey)."
[url "https://gitlab.com/"]
    insteadOf = gl:
    insteadOf = gitlab.com:

[url "ssh://aur/"]
    insteadOf = aur:
